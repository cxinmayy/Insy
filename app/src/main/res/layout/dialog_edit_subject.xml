<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:layout_marginVertical="10dp"
    app:cardCornerRadius="36dp"
    app:cardElevation="8dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/surface_level1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edit Subject"
            android:fontFamily="@font/manrope"
            android:textColor="@color/on_surface_dark"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"/>

        <EditText
            android:id="@+id/etEditName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_pill_empty"
            android:paddingHorizontal="24dp"
            android:paddingVertical="18dp"
            android:hint="Subject Name"
            android:fontFamily="@font/manrope"
            android:textSize="15sp"
            android:textColor="@color/on_surface_dark"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etEditAttended"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_pill_empty"
            android:paddingHorizontal="24dp"
            android:paddingVertical="18dp"
            android:hint="Attended"
            android:inputType="number"
            android:fontFamily="@font/manrope"
            android:textSize="15sp"
            android:textColor="@color/on_surface_dark"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etEditTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_pill_empty"
            android:paddingHorizontal="24dp"
            android:paddingVertical="18dp"
            android:hint="Total"
            android:inputType="number"
            android:fontFamily="@font/manrope"
            android:textSize="15sp"
            android:textColor="@color/on_surface_dark"
            android:layout_marginBottom="32dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelEdit"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Cancel"
                android:fontFamily="@font/manrope"
                android:textColor="@color/on_surface_variant"
                app:cornerRadius="28dp"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveEdit"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Save"
                android:fontFamily="@font/manrope"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/primary_scholarly"
                app:cornerRadius="28dp"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>