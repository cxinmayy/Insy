<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_level0"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SUBJECT INSIGHT"
            android:fontFamily="@font/manrope"
            android:textColor="@color/on_surface_variant"
            android:textSize="12sp"
            android:letterSpacing="0.05"
            android:textAllCaps="true"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvSubjectTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Academic Integrity"
            android:fontFamily="@font/manrope"
            android:textColor="@color/primary_scholarly"
            android:textSize="44sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02"
            android:lineSpacingExtra="-8dp"
            android:layout_marginBottom="12dp" />

        <!-- Decorative line under title -->
        <View
            android:layout_width="120dp"
            android:layout_height="6dp"
            android:background="@drawable/bg_progress_gradient"
            android:layout_marginBottom="32dp" />

        <!-- Data Cards Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="24dp">

            <!-- Left Card: Attendance & Total -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.6"
                android:background="@drawable/bg_card_white"
                android:orientation="vertical"
                android:elevation="0dp"
                android:layout_marginEnd="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ATTENDANCE RATE"
                            android:fontFamily="@font/manrope"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="10sp"
                            android:letterSpacing="0.05"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvAttendancePct"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:fontFamily="@font/manrope"
                            android:textColor="@color/on_surface_dark"
                            android:textSize="36sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Fake chart icon box inside primary container -->
                    <LinearLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:gravity="center"
                        android:background="@drawable/bg_card_absent"
                        android:backgroundTint="@color/surface_level1">
                        
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_sort_by_size"
                            app:tint="@color/primary_scholarly" />
                    </LinearLayout>
                </RelativeLayout>

                <!-- Present Count Label and Value -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Present"
                        android:fontFamily="@font/manrope"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvPresentCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="0"
                        android:fontFamily="@font/manrope"
                        android:textColor="@color/primary_scholarly"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <ProgressBar
                    android:id="@+id/progressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:progressDrawable="@drawable/bg_progress_gradient"
                    android:max="100"
                    android:progress="0"
                    android:layout_marginBottom="24dp" />

                <!-- Total Sessions Mini Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_absent"
                    android:backgroundTint="@color/surface_level1"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOTAL SESSIONS"
                        android:fontFamily="@font/manrope"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="10sp"
                        android:letterSpacing="0.05"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTotalCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:fontFamily="@font/manrope"
                        android:textColor="@color/on_surface_dark"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Right Card: Absent -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_card_absent"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingTop="32dp"
                android:paddingBottom="24dp">

                <!-- Alert icon -> Simple circle with icon for now -->
                <LinearLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_card_absent"
                    android:backgroundTint="#F06076"
                    android:gravity="center"
                    android:layout_marginBottom="60dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_dialog_alert"
                        app:tint="@color/absent_text" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center_horizontal|bottom">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ABSENT"
                        android:fontFamily="@font/manrope"
                        android:textColor="@color/absent_text"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvAbsentCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:fontFamily="@font/manrope"
                        android:textColor="@color/absent_text"
                        android:textSize="48sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- Calendar Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_white"
            android:backgroundTint="@color/surface_level1"
            android:elevation="0dp"
            android:padding="8dp">

            <com.prolificinteractive.materialcalendarview.MaterialCalendarView
                android:id="@+id/calendarView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:mcv_showOtherDates="all"
                app:mcv_selectionColor="@color/primary_container"
                app:mcv_headerTextAppearance="@style/TextAppearance.AppCompat.Medium"
                app:mcv_dateTextAppearance="@style/TextAppearance.AppCompat.Body1" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>