<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:paddingEnd="24dp">

    <TextView
        android:id="@+id/tvPerfPercentage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="50.0"
        android:fontFamily="@font/manrope"
        android:textColor="@color/primary_scholarly"
        android:alpha="0.7"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <!-- Pill Container -->
    <androidx.cardview.widget.CardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="70dp"
        android:layout_height="100dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/track_empty"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:weightSum="100">

            <View
                android:id="@+id/viewChartEmpty"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="50"/>

            <View
                android:id="@+id/viewChartFill"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="50"
                android:background="@color/primary_scholarly"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvPerfSubject"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ai"
        android:fontFamily="@font/manrope"
        android:textColor="@color/on_surface_dark"
        android:textSize="14sp"
        android:textStyle="bold"/>

</LinearLayout>
